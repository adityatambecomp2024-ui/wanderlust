<% layout("/layout/boilerplate") %>

<script>
const maptoken = "<%= process.env.MAP_TOKEN %>";
const listing = <%- JSON.stringify({
  title: list.title,
  geometry: list.geometry,
  location: list.location
}) %>;
</script>

<div class="container mt-4">

  <!-- Hero Section -->
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

        <% if(list.image && list.image.length > 0){ %>
          <img src="<%= list.image[0].path %>" 
               class="card-img-top" 
               style="height:400px; object-fit:cover;">
        <% } %>

        <div class="card-body p-4">

          <div class="d-flex justify-content-between align-items-start">
            <div>
              <h2 class="fw-bold"><%= list.title %></h2>
              <p class="text-muted mb-1">📍 <%= list.location %>, <%= list.country %></p>
              <p class="text-muted mb-2">👤 Owned by <b><%= list.owner.username %></b></p>
            </div>
            <div class="text-end">
              <h3 class="text-success fw-bold">₹ <%= list.price %></h3>
              <small class="text-muted">per night</small>
            </div>
          </div>

          <hr>
          <p class="text-secondary"><%= list.description %></p>

          <!-- Book Now Button -->
          <div class="mt-3">
            <% if(userData){ %>
              <button class="btn btn-success w-100 py-2 fw-bold"
                data-bs-toggle="modal" 
                data-bs-target="#bookingModal">
                🏨 Book Now
              </button>
            <% } else { %>
              <a href="/login" class="btn btn-primary w-100 py-2 fw-bold">
                🔐 Login to Book
              </a>
            <% } %>
          </div>

          <!-- ✅ Owner buttons -->
          <% if(userData && userData._id.equals(list.owner._id)){ %>
            <div class="d-flex gap-2 mt-3">

              <a href="/listing/<%= list._id %>/edit" 
                 class="btn btn-warning btn-sm flex-fill">✏️ Edit</a>

              <form method="POST" 
                    action="/listing/<%= list._id %>?_method=DELETE" 
                    style="display:contents">
                <button class="btn btn-danger btn-sm flex-fill">🗑️ Delete</button>
              </form>

              <!-- ✅ Add Hotel always show -->
              <a href="/listing/<%= list._id %>/hotels/new" 
                 class="btn btn-success btn-sm flex-fill">+ Add Hotel</a>

              <!-- ✅ Add Rooms - Hotel असेल तरच -->
              <% if(list.Hotel && list.Hotel.length > 0){ %>
                <a href="/listing/<%= list._id %>/hotels/<%= list.Hotel[0]._id %>/addrooms" 
                   class="btn btn-primary btn-sm flex-fill">🛏️ Add Rooms</a>
              <% } %>

            </div>
          <% } %>

        </div>
      </div>

    </div>
  </div>

  <!-- ✅ Rooms Section -->
  <% if(list.Hotel && list.Hotel.length > 0){ %>
    <div class="row justify-content-center mt-4">
      <div class="col-lg-8">
        <h4 class="fw-bold mb-3">🛏️ Available Rooms</h4>
        <div class="row row-cols-1 row-cols-md-3 g-3">

          <% list.Hotel.forEach(hotel => { %>
            <% if(hotel.rooms && hotel.rooms.length > 0){ %>
              <% hotel.rooms.forEach((room, index) => { %>

                <div class="col">
                  <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden">

                    <% if(room.photos && room.photos.length > 0){ %>
                      <div id="roomCarousel-<%= hotel._id %>-<%= index %>" 
                           class="carousel slide" data-bs-ride="carousel">
                        <div class="carousel-inner">
                          <% room.photos.forEach((photo, i) => { %>
                            <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
                              <img src="<%= photo.path %>" 
                                   class="d-block w-100"
                                   style="height:180px; object-fit:cover;">
                            </div>
                          <% }) %>
                        </div>
                        <% if(room.photos.length > 1){ %>
                          <button class="carousel-control-prev" type="button"
                            data-bs-target="#roomCarousel-<%= hotel._id %>-<%= index %>"
                            data-bs-slide="prev">
                            <span class="carousel-control-prev-icon"></span>
                          </button>
                          <button class="carousel-control-next" type="button"
                            data-bs-target="#roomCarousel-<%= hotel._id %>-<%= index %>"
                            data-bs-slide="next">
                            <span class="carousel-control-next-icon"></span>
                          </button>
                        <% } %>
                      </div>
                    <% } else { %>
                      <div class="bg-light d-flex align-items-center justify-content-center" 
                           style="height:180px">
                        <p class="text-muted">📷 No photos</p>
                      </div>
                    <% } %>

                    <div class="card-body p-3">
                      <h6 class="fw-bold">🛏️ <%= room.roomType %> Room</h6>
                      <p class="text-muted small mb-1"><%= room.description %></p>
                      <p class="small mb-1">👥 Capacity: <%= room.capacity %> persons</p>
                      <p class="fw-bold text-success mb-0">₹ <%= room.price %> / night</p>
                    </div>

                  </div>
                </div>

              <% }) %>
            <% } %>
          <% }) %>

        </div>
      </div>
    </div>
  <% } %>

  <!-- Reviews Section -->
  <div class="row justify-content-center mt-5">
    <div class="col-lg-8">

      <div class="card shadow-sm border-0 rounded-4 p-4">
        <h4 class="fw-bold mb-3">⭐ Add Review</h4>
        <form method="POST" action="/listing/<%= list._id %>/reviews">
          <div class="mb-2">
            <label class="fw-bold">Rating</label><br>
            <% for(let i=1; i<=5; i++){ %>
              <input type="radio" name="review[Rating]" value="<%= i %>"> <%= i %>⭐
            <% } %>
          </div>
          <textarea name="review[comment]" 
                    class="form-control mb-2" 
                    placeholder="Write your review..."
                    required></textarea>
          <button class="btn btn-dark w-100">Submit Review</button>
        </form>
      </div>

      <% if(list.review && list.review.length > 0){ %>
        <h4 class="fw-bold mt-4 mb-3">💬 All Reviews</h4>
        <div class="row g-3">
          <% list.review.forEach(review => { %>
            <div class="col-lg-6">
              <div class="card shadow-sm border-0 rounded-3 p-3">
                <h6 class="fw-bold">👤 <%= review.author.username %></h6>
                <p class="text-muted mb-1"><%= review.comment %></p>
                <p class="text-warning mb-0">
                  <% for(let i=0; i<review.Rating; i++){ %>⭐<% } %>
                </p>
                <% if(userData && review.author._id.equals(userData._id)){ %>
                  <form method="POST"
                    action="/listing/<%= list._id %>/reviews/<%= review._id %>?_method=DELETE"
                    class="mt-2">
                    <button class="btn btn-danger btn-sm">Delete</button>
                  </form>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="text-center text-muted mt-3">No reviews yet</p>
      <% } %>

    </div>
  </div>

  <!-- Map Section -->
  <div class="row justify-content-center mt-5 mb-5">
    <div class="col-lg-8">
      <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-body p-3">
          <h4 class="fw-bold">📍 Where you'll be</h4>
          <div id="map" style="height:400px; border-radius:12px;"></div>
        </div>
      </div>
    </div>
  </div>

</div>

<!-- Booking Modal -->
<div class="modal fade" id="bookingModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content rounded-4">
      <div class="modal-header bg-success text-white">
        <h5 class="modal-title fw-bold">🏨 Book Hotel</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" action="/listing/<%= list._id %>/bookings">
        <div class="modal-body p-4">
          <label class="fw-bold">Check-in</label>
          <input type="date" name="booking[startDate]" 
                 class="form-control mb-3" id="startDate" required>
          <label class="fw-bold">Check-out</label>
          <input type="date" name="booking[endDate]" 
                 class="form-control mb-3" id="endDate" required>
          <label class="fw-bold">Guests</label>
          <input type="number" name="booking[guests]" 
                 class="form-control" value="1" min="1">
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" 
                  data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-success fw-bold px-4">
            ✅ Confirm Booking
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="/JS/map.js"></script>