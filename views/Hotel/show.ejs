<% layout("layout/boilerplate") %>

<div class="container mt-4">

  <h3 class="text-center"><%= list.title %></h3>

  <div class="row justify-content-center">
    <div class="col-lg-6">

      <div class="card">

        <% if(list.image && list.image.length > 0){ %>
          <img src="<%= list.image[0].path %>" 
               class="card-img-top" 
               style="height:300px; object-fit:cover;">
        <% } %>

        <div class="card-body">

          <b>Owned by <%= list.owner.username %></b><br><br>

          <p><%= list.description %></p>
          <p>₹ <%= list.price %> per night</p>
          <p><%= list.location %>, <%= list.country %></p>

          <div class="mt-3">
            <% if(userData){ %>
              <button class="btn btn-success w-100"
                onclick="openBookingForm('<%= list._id %>')">
                Book Now
              </button>
            <% } else { %>
              <a href="/login" class="btn btn-primary w-100">
                Login to Book
              </a>
            <% } %>
          </div>

        </div>
      </div>

    </div>
  </div>

</div>

<!-- ✅ Rooms Gallery Section -->
<div class="container mt-5">
  <h3>🛏️ Available Rooms</h3>

  <% if(list.rooms && list.rooms.length > 0){ %>
    <div class="row">
      <% list.rooms.forEach((room, index) => { %>

        <div class="col-lg-4 col-md-6 mb-4">
          <div class="card h-100 shadow-sm">

            <!-- Room Photos Carousel -->
            <% if(room.photos && room.photos.length > 0){ %>
              <div id="carousel-<%= index %>" 
                   class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                  <% room.photos.forEach((photo, i) => { %>
                    <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
                      <img src="<%= photo.path %>" 
                           class="d-block w-100" 
                           style="height:200px; object-fit:cover;">
                    </div>
                  <% }) %>
                </div>
                <% if(room.photos.length > 1){ %>
                  <button class="carousel-control-prev" 
                          type="button" 
                          data-bs-target="#carousel-<%= index %>" 
                          data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                  </button>
                  <button class="carousel-control-next" 
                          type="button" 
                          data-bs-target="#carousel-<%= index %>" 
                          data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                  </button>
                <% } %>
              </div>
            <% } else { %>
              <div class="bg-light d-flex align-items-center 
                          justify-content-center" 
                   style="height:200px">
                <p class="text-muted">📷 No photos</p>
              </div>
            <% } %>

            <div class="card-body">
              <h5>🛏️ <%= room.roomType %> Room</h5>
              <p class="text-muted"><%= room.description %></p>
              <p>👥 Capacity: <%= room.capacity %> persons</p>
              <p class="fw-bold text-success">₹ <%= room.price %> / night</p>
            </div>

            <div class="card-footer">
              <% if(userData){ %>
                <button class="btn btn-success w-100"
                  onclick="openBookingForm('<%= list._id %>')">
                  Book This Room
                </button>
              <% } else { %>
                <a href="/login" class="btn btn-primary w-100">
                  Login to Book
                </a>
              <% } %>
            </div>

          </div>
        </div>

      <% }) %>
    </div>

  <% } else { %>
    <div class="text-center mt-3">
      <p class="text-muted">No rooms added yet</p>
    </div>
  <% } %>

</div>

<!-- Booking Modal -->
<div class="modal fade" id="bookingModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Book Hotel</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <form id="bookingForm" method="POST">
        <div class="modal-body">

          <label>Check-in</label>
          <input type="date" name="booking[startDate]" 
                 class="form-control" id="startDate" required>

          <label class="mt-2">Check-out</label>
          <input type="date" name="booking[endDate]" 
                 class="form-control" id="endDate" required>

          <label class="mt-2">Guests</label>
          <input type="number" name="booking[guests]" 
                 class="form-control" value="1" min="1">

        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" 
                  data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-success">
            Confirm Booking
          </button>
        </div>
      </form>

    </div>
  </div>
</div>

<!-- Reviews -->
<div class="container mt-5">
  <h4>Reviews</h4>

  <div class="row">
    <% if(list.review && list.review.length > 0){ %>
      <% list.review.forEach(r => { %>

        <div class="card col-lg-4 m-2">
          <div class="card-body">
            <h5><%= r.author.username %></h5>
            <p><%= r.comment %></p>
            <p>Rating: <%= r.Rating %></p>
          </div>
        </div>

      <% }) %>
    <% } else { %>
      <p>No reviews yet</p>
    <% } %>
  </div>
</div>

<!-- JS -->
<script>
function openBookingForm(hotelId) {
  document.getElementById("bookingForm").action =
    "/listing/<%= id %>/hotels/" + hotelId + "/bookings";

  const today = new Date().toISOString().split("T")[0];
  document.getElementById("startDate").min = today;
  document.getElementById("endDate").min = today;

  const modal = new bootstrap.Modal(
    document.getElementById("bookingModal")
  );
  modal.show();

  document.getElementById("startDate").addEventListener("change", function() {
    document.getElementById("endDate").min = this.value;
  });
}
</script>