<% layout("./layout/boilerplate.ejs") %>

<form method="POST" 
      action="/listing/<%= id %>/hotels/<%= hotelid %>/addrooms"
      enctype="multipart/form-data">
  <div class="row">
    <div class="col-6 offset-3">

      <h2 class="mt-4">🛏️ Add Rooms</h2>

      <div id="roomsContainer">
        <div class="room-card border p-3 mb-3 rounded bg-light">
          <h5>Room 1</h5>
          <div class="mb-2">
            <label>Room Type</label>
            <select name="rooms[0][roomType]" class="form-control">
              <option value="Standard">Standard</option>
              <option value="Deluxe">Deluxe</option>
              <option value="Suite">Suite</option>
              <option value="Family">Family</option>
            </select>
          </div>
          <div class="mb-2">
            <label>Price per night (₹)</label>
            <input type="number" name="rooms[0][price]" 
                   class="form-control" placeholder="2000">
          </div>
          <div class="mb-2">
            <label>Capacity (persons)</label>
            <input type="number" name="rooms[0][capacity]" 
                   class="form-control" value="2" min="1">
          </div>
          <div class="mb-2">
            <label>Description</label>
            <input type="text" name="rooms[0][description]" 
                   class="form-control" placeholder="AC, TV, WiFi...">
          </div>
          <div class="mb-2">
            <label>Room Photos</label>
            <input type="file" name="roomPhotos_0" 
                   class="form-control" multiple accept="image/*">
          </div>
        </div>
      </div>

      <button type="button" class="btn btn-outline-primary mb-3" 
              onclick="addRoom()">+ Add Another Room</button>

      <hr>

      <button class="mt-3 mb-3 btn btn-success w-100">
        💾 Save Rooms
      </button>

    </div>
  </div>
</form>

<script>
let roomCount = 1;
function addRoom() {
  const container = document.getElementById("roomsContainer");
  const div = document.createElement("div");
  div.className = "room-card border p-3 mb-3 rounded bg-light";
  div.innerHTML = `
    <h5>Room ${roomCount + 1}
      <button type="button" class="btn btn-sm btn-danger float-end" 
              onclick="this.closest('.room-card').remove()">✕</button>
    </h5>
    <div class="mb-2">
      <label>Room Type</label>
      <select name="rooms[${roomCount}][roomType]" class="form-control">
        <option value="Standard">Standard</option>
        <option value="Deluxe">Deluxe</option>
        <option value="Suite">Suite</option>
        <option value="Family">Family</option>
      </select>
    </div>
    <div class="mb-2">
      <label>Price per night (₹)</label>
      <input type="number" name="rooms[${roomCount}][price]" 
             class="form-control" placeholder="2000">
    </div>
    <div class="mb-2">
      <label>Capacity (persons)</label>
      <input type="number" name="rooms[${roomCount}][capacity]" 
             class="form-control" value="2" min="1">
    </div>
    <div class="mb-2">
      <label>Description</label>
      <input type="text" name="rooms[${roomCount}][description]" 
             class="form-control" placeholder="AC, TV, WiFi...">
    </div>
    <div class="mb-2">
      <label>Room Photos</label>
      <input type="file" name="roomPhotos_${roomCount}" 
             class="form-control" multiple accept="image/*">
    </div>
  `;
  container.appendChild(div);
  roomCount++;
}
</script>