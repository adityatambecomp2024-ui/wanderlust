<% layout("./layout/boilerplate.ejs") %>

<div class="container mt-4">

  <h2 class="mb-4">Available Hotels</h2>

  <div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-1 g-4">

    <% if(list.Hotel && list.Hotel.length > 0){ %>

      <% list.Hotel.forEach(li => { %>

        <div class="col">
          <div class="card h-100">

            <!-- ✅ Hotel click केल्यावर show page उघडेल -->
            <a href="/listing/<%= id %>/hotels/<%= li._id %>" 
               style="text-decoration:none; color:black">

              <!-- ✅ Hotel Photos Carousel -->
              <% if(li.image && li.image.length > 1){ %>
                <div id="carousel-<%= li._id %>" 
                     class="carousel slide" 
                     data-bs-ride="carousel">
                  <div class="carousel-inner">
                    <% li.image.forEach((img, i) => { %>
                      <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
                        <img src="<%= img.path %>" 
                             class="card-img-top" 
                             style="height:200px; object-fit:cover;">
                      </div>
                    <% }) %>
                  </div>
                  <button class="carousel-control-prev" 
                          type="button" 
                          data-bs-target="#carousel-<%= li._id %>" 
                          data-bs-slide="prev"
                          onclick="event.preventDefault()">
                    <span class="carousel-control-prev-icon"></span>
                  </button>
                  <button class="carousel-control-next" 
                          type="button" 
                          data-bs-target="#carousel-<%= li._id %>" 
                          data-bs-slide="next"
                          onclick="event.preventDefault()">
                    <span class="carousel-control-next-icon"></span>
                  </button>
                </div>
              <% } else if(li.image && li.image.length === 1){ %>
                <img src="<%= li.image[0].path %>" 
                     class="card-img-top" 
                     style="height:200px; object-fit:cover;">
              <% } else { %>
                <div class="bg-light d-flex align-items-center 
                            justify-content-center" 
                     style="height:200px">
                  <p class="text-muted">No photo</p>
                </div>
              <% } %>

              <div class="card-body">
                <h5 class="card-title"><%= li.title %></h5>
                <p class="card-text text-muted">
                  📍 <%= li.location %>
                </p>
                <p class="card-text fw-bold text-success">
                  ₹ <%= li.price %> / night
                </p>
                <!-- ✅ Rooms count दाखवा -->
                <% if(li.rooms && li.rooms.length > 0){ %>
                  <p class="card-text">
                    🛏️ <%= li.rooms.length %> Room types available
                  </p>
                <% } %>
              </div>

            </a>

            <div class="card-footer p-2">
              <% if(userData){ %>
                <button class="btn btn-success btn-sm w-100"
                  onclick="openBookingForm('<%= li._id %>', '<%= li.title %>')">
                  Book Now
                </button>
              <% } else { %>
                <a href="/login" class="btn btn-primary btn-sm w-100">
                  Login to Book
                </a>
              <% } %>
            </div>

          </div>
        </div>

      <% }) %>

    <% } else { %>

      <div class="col-12 text-center mt-5">
        <h4>No hotels available</h4>
      </div>

    <% } %>

  </div>

</div>

<!-- Booking Modal -->
<div class="modal fade" id="bookingModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Book Hotel</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <form id="bookingForm" method="POST">
        <div class="modal-body">

          <div class="mb-3">
            <label>Hotel</label>
            <input type="text" id="hotelTitle" class="form-control" readonly>
          </div>

          <div class="row">
            <div class="col">
              <label>Check-in</label>
              <input type="date" name="booking[startDate]" 
                     class="form-control" id="startDate" required>
            </div>
            <div class="col">
              <label>Check-out</label>
              <input type="date" name="booking[endDate]" 
                     class="form-control" id="endDate" required>
            </div>
          </div>

          <div class="mt-3">
            <label>Guests</label>
            <input type="number" name="booking[guests]" 
                   class="form-control" value="1" min="1" max="10">
          </div>

        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" 
                  data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-success">
            Confirm Booking
          </button>
        </div>
      </form>

    </div>
  </div>
</div>

<script>
function openBookingForm(hotelId, hotelTitle) {
  document.getElementById("hotelTitle").value = hotelTitle;
  document.getElementById("bookingForm").action =
    "/listing/<%= id %>/hotels/" + hotelId + "/bookings";

  const today = new Date().toISOString().split("T")[0];
  document.getElementById("startDate").min = today;
  document.getElementById("endDate").min = today;

  const modal = new bootstrap.Modal(
    document.getElementById("bookingModal")
  );
  modal.show();

  document.getElementById("startDate").addEventListener("change", function() {
    document.getElementById("endDate").min = this.value;
  });
}
</script>