<% layout("/layout/boilerplate") %>

<div class="container mt-4">

  <h2 class="mb-4">🏨 My Bookings</h2>

  <% if(bookings && bookings.length > 0){ %>

    <div class="row">
      <% bookings.forEach(booking => { %>

        <div class="col-lg-4 col-md-6 mb-4">
          <div class="card h-100 shadow-sm">

            <% if(booking.hotel && booking.hotel.image && booking.hotel.image.length > 0){ %>
              <img src="<%= booking.hotel.image[0].path %>" 
                   class="card-img-top" 
                   style="height:200px; object-fit:cover;">
            <% } %>

            <div class="card-body">

              <h5 class="card-title">
                <%= booking.hotel ? booking.hotel.title : "Hotel Deleted" %>
              </h5>

              <p class="text-muted">
                📍 <%= booking.hotel ? booking.hotel.location : "-" %>
              </p>

              <hr>

              <p>
                <b>Check-in:</b> 
                <%= new Date(booking.startDate).toDateString() %>
              </p>
              <p>
                <b>Check-out:</b> 
                <%= new Date(booking.endDate).toDateString() %>
              </p>
              <p>
                <b>Guests:</b> <%= booking.guests %>
              </p>

              <% if(booking.hotel && booking.startDate && booking.endDate){ %>
                <% 
                  const days = Math.ceil((new Date(booking.endDate) - new Date(booking.startDate)) / (1000*60*60*24));
                  const total = days * booking.hotel.price;
                %>
                <p><b>Total:</b> ₹ <%= total %> (<%= days %> nights)</p>
              <% } %>

            </div>

            <!-- ✅ Cancel button add केला -->
            <div class="card-footer d-flex justify-content-between align-items-center">
              <span class="badge bg-success">Confirmed ✓</span>

              <div>
                <% if(booking.hotel){ %>
                  <a href="/listing/<%= booking.hotel._id %>" 
                     class="btn btn-sm btn-outline-primary">
                    View Hotel
                  </a>
                <% } %>

                <form method="POST" 
                      action="/bookings/<%= booking._id %>?_method=DELETE"
                      style="display:inline"
                      onsubmit="return confirm('Are you sure you want to cancel this booking?')">
                  <button class="btn btn-sm btn-danger">
                    Cancel ✕
                  </button>
                </form>
              </div>
            </div>

          </div>
        </div>

      <% }) %>
    </div>

  <% } else { %>

    <div class="text-center mt-5">
      <h4>No bookings yet!</h4>
      <a href="/listing" class="btn btn-success mt-3">
        Explore Hotels
      </a>
    </div>

  <% } %>

</div>