<% layout("/layout/boilerplate") %>

<div class="container mt-4">

  <h2 class="mb-4">📊 Owner Booking History</h2>

  <% if(bookings && bookings.length > 0){ %>

    <div class="row">
      <% bookings.forEach(booking => { %>

        <div class="col-lg-4 col-md-6 mb-4">
          <div class="card h-100 shadow-sm">

            <div class="card-body">

              <h5><%= booking.hotel.title %></h5>

              <p>👤 User: <%= booking.user.username %></p>

              <p>📅 From: <%= new Date(booking.startDate).toDateString() %></p>
              <p>📅 To: <%= new Date(booking.endDate).toDateString() %></p>

              <p>👥 Guests: <%= booking.guests %></p>
              <p>💰 Amount: ₹ <%= booking.amount %></p>

              <% if(booking.paymentStatus === 'paid'){ %>
                <span class="badge bg-success">Paid</span>
              <% } else { %>
                <span class="badge bg-warning">Pending</span>
              <% } %>

            </div>

          </div>
        </div>

      <% }) %>
    </div>

  <% } else { %>

    <h4>No bookings received</h4>

  <% } %>

</div>